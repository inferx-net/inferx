{
    "type": "function",
    "tenant": "public",
    "namespace": "Trial",
    "name": "inferx-RAG-bundle-Qwen3.6-35B-A3B-FP8",
    "object": {
        "spec": {
            "image": "inferx/inferx-bundle:v0.19.0",
            "commands": [
                "python3 -m vllm.entrypoints.openai.api_server --model Qwen/Qwen3-Reranker-0.6B --gpu-memory-utilization 0.05 --enable-sleep-mode --max-model-len 1200 --runner pooling --port 8002",
                "python3 -m vllm.entrypoints.openai.api_server --model Qwen/Qwen3-Embedding-0.6B --gpu-memory-utilization 0.05 --enable-sleep-mode --max-model-len 1200 --runner pooling --port 8003",
                "python3 -m vllm.entrypoints.openai.api_server --model Qwen/Qwen3.6-35B-A3B-FP8 --gpu-memory-utilization 0.80 --enable-sleep-mode --max-model-len 32000 --max-num-batched-tokens 4096  --enable-chunked-prefill --enable-prefix-caching -port 8001"
